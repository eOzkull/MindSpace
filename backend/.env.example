# MindSpace Backend Environment Configuration Template

# Flask runtime environment (development or production)
FLASK_ENV=development

# Secret key used for session signing and encryption
SECRET_KEY=dev_secret_key_mindspace_change_in_prod

# Cookie security settings (true or false)
COOKIE_SECURE=false

# Allowed CORS origins, comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Temporary directory for static plots
STATIC_PLOT_DIR=static/plots
